@model IEnumerable<TepihServisManager.Models.Narudzbina>

@{
    ViewBag.Title = "Moje Narudžbine";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark">📋 Moje Narudžbine</h2>
            <p class="text-muted mb-0">Pregled svih Vaših zahtjeva za pranje tepiha</p>
        </div>
        <a href="@Url.Action("NovaNarudzbina", "Korisnik")" class="btn btn-primary btn-lg shadow-sm">
            ➕ Nova Narudžbina
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <h5 class="text-muted">Nemate istoriju narudžbina.</h5>
                    <p class="text-muted small">Kliknite na dugme iznad da pošaljete svoj prvi tepih na pranje!</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4 py-3">ID Narudžbine</th>
                                <th class="py-3">Datum kreiranja</th>
                                <th class="py-3">Status</th>
                                <th class="py-3">Ukupna Cijena</th>
                                <th class="pe-4 py-3 text-end">Detalji</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-secondary">#@item.NarudzbinaID</td>
                                    <td>
                                        @(item.Datum.HasValue ? item.Datum.Value.ToString("dd.MM.yyyy. HH:mm") : "Nema datuma")
                                    </td>
                                    <td>
                                        @if (item.StatusNarudzbine != null)
                                        {
                                            <span class="badge bg-info text-dark rounded-pill px-3 py-2 fw-semibold">
                                                @item.StatusNarudzbine.Naziv
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill px-3 py-2">Nepoznato</span>
                                        }
                                    </td>

                                    <td class="fw-bold text-success">
                                        @{
                                            // Preko .Sum(s => s.Cijena) izvlačimo zbir koji može biti null,
                                            // a sa ?? 0 ga pretvaramo u običnu nulu i rješavamo crvenilo!
                                            decimal ukupno = item.StavkaNarudzbine != null
                                                             ? (item.StavkaNarudzbine.Sum(s => s.Cijena) ?? 0)
                                                             : 0;
                                        }
                                        @if (ukupno > 0)
                                        {
                                            <span>@ukupno.ToString("0.00") €</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small fw-normal">U obradi (čeka mjerenje)</span>
                                        }
                                    </td>

                                    <td class="pe-4 text-end">
                                        <span class="badge bg-light text-secondary rounded-pill border px-3 py-2">U obradi</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
    <div class="card mt-4 shadow-sm border-0 rounded-3">
        <div class="card-body">
            <h5 class="fw-bold mb-3">💬 Ostavite utisak o našoj usluzi</h5>
            @using (Html.BeginForm("DodajOcjenuIKomentar", "Korisnik", FormMethod.Post, new { @class = "row g-3" }))
            {
                @Html.AntiForgeryToken()
                <div class="col-md-3">
                    <label class="form-label">Ocjena:</label>
                    <select name="ocjena" class="form-select">
                        <option value="5">⭐⭐⭐⭐⭐ (5)</option>
                        <option value="4">⭐⭐⭐⭐ (4)</option>
                        <option value="3">⭐⭐⭐ (3)</option>
                        <option value="2">⭐⭐ (2)</option>
                        <option value="1">⭐ (1)</option>
                    </select>
                </div>
                <div class="col-md-7">
                    <label class="form-label">Vaš komentar:</label>
                    <input type="text" name="tekstKomentara" class="form-control" placeholder="Napišite nešto o našoj usluzi..." required />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Pošalji</button>
                </div>
            }
        </div>
    </div>
</div>