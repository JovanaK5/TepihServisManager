@{
    ViewBag.Title = "Prijava na sistem";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0 fw-bold">🔐 Tepih Servis Login</h4>
                </div>
                <div class="card-body p-4">

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger shadow-sm">
                            ⚠️ @ViewBag.Error
                        </div>
                    }

                    <form action="@Url.Action("Login", "Account")" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-bold">Email adresa</label>
                            <input type="email" name="email" class="form-control" placeholder="unesite@email.com" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Vaša Lozinka</label>
                            <input type="password" name="lozinka" class="form-control" placeholder="••••••••" required />
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">Prijavi se</button>
                        </div>

                        <p class="text-center mt-3 mb-0 text-muted">
                            Nemate nalog? <a href="@Url.Action("Register","Account")" class="text-primary fw-bold text-decoration-none">Registrujte se</a>
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>