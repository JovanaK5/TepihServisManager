@model IEnumerable<TepihServisManager.Models.Narudzbina>

@{
    ViewBag.Title = "Pregled Svih Narudžbina";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-5 px-4">
    <div class="mb-4">
        <h2 class="fw-bold text-dark">⚙️ Admin Panel: Sve Narudžbine</h2>
        <p class="text-muted">Pregled, brza pretraga i upravljanje statusima svih zahtjeva u servisu</p>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm mb-4">
            ⚠️ @TempData["Error"]
        </div>
    }

    <div class="card shadow-sm border-0 bg-light mb-4 rounded-3">
        <div class="card-body p-3">
            <form action="@Url.Action("SveNarudzbine", "Admin")" method="get" class="row g-3 align-items-center">

                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white text-muted">🔍</span>
                        <input type="text" name="pojamPretrage" class="form-control"
                               placeholder="Pretraži po imenu klijenta ili telefonu..."
                               value="@ViewBag.TrenutnaPretraga" />
                    </div>
                </div>

                <div class="col-md-4">
                    <select name="statusFilter" class="form-select">
                        <option value="0">-- Filtriraj po statusu (Sve) --</option>
                        @if (ViewBag.Statusi != null)
                        {
                            foreach (var status in ViewBag.Statusi)
                            {
                                <option value="@status.StatusID" @(ViewBag.TrenutniStatusFilter == status.StatusID ? "selected" : "")>
                                    @status.Naziv
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100 fw-bold">Filtriraj</button>
                    @if (!string.IsNullOrEmpty(ViewBag.TrenutnaPretraga) || ViewBag.TrenutniStatusFilter != null)
                    {
                        <a href="@Url.Action("SveNarudzbine", "Admin")" class="btn btn-outline-secondary px-3" title="Poništi filtere">X</a>
                    }
                </div>

            </form>
        </div>
    </div>

    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <h5 class="text-muted mb-0">Nema pronađenih narudžbina za unijete kriterijume pretrage.</h5>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-4 py-3">ID</th>
                                <th class="py-3">Klijent</th>
                                <th class="py-3">Telefon</th>
                                <th class="py-3">Datum Primanja</th>
                                <th class="py-3">Trenutni Status</th>
                                <th class="py-3">Ukupna Cijena</th>
                                <th class="pe-4 py-3 text-center" style="width: 300px;">Ažuriraj Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">#@item.NarudzbinaID</td>
                                    <td>
                                        <div class="fw-bold text-dark">
                                            @(item.Klijent != null && item.Klijent.Korisnik != null ? item.Klijent.Korisnik.Ime : "Nepoznat klijent")
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-secondary">@(item.Klijent != null ? item.Klijent.Telefon : "-")</span>
                                    </td>
                                    <td>
                                        @(item.Datum.HasValue ? item.Datum.Value.ToString("dd.MM.yyyy. HH:mm") : "Nema datuma")
                                    </td>
                                    <td>
                                        @if (item.StatusNarudzbine != null)
                                        {
                                            string klasaBoje = item.StatusID == 1 ? "bg-warning text-dark" : item.StatusID == 2 ? "bg-info text-dark" : "bg-success text-white";
                                            <span class="badge @klasaBoje rounded-pill px-3 py-2 fw-semibold">
                                                @item.StatusNarudzbine.Naziv
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill px-3 py-2">Nepoznat status</span>
                                        }
                                    </td>

                                    <td class="fw-bold text-success">
                                        @{
                                            decimal ukupno = item.StavkaNarudzbine != null
                                                             ? (item.StavkaNarudzbine.Sum(s => s.Cijena) ?? 0)
                                                             : 0;
                                        }
                                        @if (ukupno > 0)
                                        {
                                            <span>@ukupno.ToString("0.00") €</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small fw-normal">Nije izmjereno</span>
                                        }
                                    </td>

                                    <td class="pe-4">
                                        <form action="@Url.Action("PromijeniStatus", "Admin")" method="post" class="d-flex gap-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="narudzbinaId" value="@item.NarudzbinaID" />

                                            <select name="noviStatusId" class="form-select form-select-sm">
                                                @if (ViewBag.Statusi != null)
                                                {
                                                    foreach (var status in ViewBag.Statusi)
                                                    {
                                                        <option value="@status.StatusID" @(item.StatusID == status.StatusID ? "selected" : "")>
                                                            @status.Naziv
                                                        </option>
                                                    }
                                                }
                                            </select>

                                            <button type="submit" class="btn btn-sm btn-dark fw-bold px-3">
                                                Snimi
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>