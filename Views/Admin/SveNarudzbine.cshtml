@model IEnumerable<TepihServisManager.Models.Narudzbina>

@{
    ViewBag.Title = "Pregled Svih Narudžbina";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-5 px-4">
    <div class="mb-4">
        <h2 class="fw-bold text-dark">⚙️ Admin Panel: Sve Narudžbine</h2>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm mb-4">⚠️ @TempData["Error"]</div>
    }

    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4 py-3">ID</th>
                            <th class="py-3">Klijent</th>
                            <th class="py-3">Datum</th>
                            <th class="py-3">Ukupna Cijena</th>
                            <th class="pe-4 py-3 text-center">Ažuriraj Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-primary">#@item.NarudzbinaID</td>
                                <td>@(item.Klijent?.Korisnik?.Ime ?? "Nepoznat")</td>
                                <td>@(item.Datum?.ToString("dd.MM.yyyy.") ?? "-")</td>
                                <td class="fw-bold text-success">
                                    @{ decimal ukupno = item.StavkaNarudzbine?.Sum(s => s.Cijena) ?? 0; }
                                    @(ukupno > 0 ? ukupno.ToString("0.00") + " €" : "Nije izmjereno")
                                </td>
                                <td class="pe-4">
                                    <form action="@Url.Action("PromijeniStatus", "Admin")" method="post" class="d-flex gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="narudzbinaId" value="@item.NarudzbinaID" />
                                        <select name="noviStatusId" class="form-select form-select-sm">
                                            @foreach (var status in ViewBag.Statusi)
                                            {
                                                <option value="@status.StatusID" @(item.StatusID == status.StatusID ? "selected" : "")>@status.Naziv</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-dark">Snimi</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>